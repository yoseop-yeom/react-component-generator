{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*credential*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*secrets*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*credential*)",
      "Edit(**/*credentials*)",
      "Edit(**/*secret*)",
      "Edit(**/*secrets*)",
      "Grep(**/.env)",
      "Grep(**/.env.*)",
      "Grep(**/*credential*)",
      "Grep(**/*secret*)",
      "Bash(cat *.env*)",
      "Bash(cat **/.env*)",
      "Bash(cat **/*credential*)",
      "Bash(cat **/*secret*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
